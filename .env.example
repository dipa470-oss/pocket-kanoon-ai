# Supabase (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional: production site URL for SSR auth redirects (defaults to window.location.origin in browser)
# VITE_SITE_URL=https://your-domain.com

# Google OAuth: enable in Supabase Dashboard → Authentication → Providers → Google.
# Add redirect URLs (Authentication → URL Configuration):
#   http://localhost:5173/auth
#   http://localhost:8080/auth
#   https://your-domain.com/auth

# Supabase (server — mirror VITE_* values for /api routes)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Optional for local dev (UI + auth work without it). Required in production for billing/webhooks.
# Copy .env.local.example → .env.local for a full local template.
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay — create monthly plans in Razorpay Dashboard, then set plan IDs here
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Public key for Checkout.js (same as RAZORPAY_KEY_ID)
VITE_RAZORPAY_KEY_ID=

# Razorpay plan IDs (plan_xxx from Dashboard → Subscriptions → Plans)
RAZORPAY_PLAN_PREMIUM=
RAZORPAY_PLAN_PREMIUM_PLUS=

# Webhook URL (production): https://your-domain.com/api/webhooks/razorpay
