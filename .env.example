# Supabase (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase (server)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay — create monthly plans in Razorpay Dashboard, then set plan IDs here
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Public key for Checkout.js (same as RAZORPAY_KEY_ID)
VITE_RAZORPAY_KEY_ID=

# Razorpay plan IDs (plan_xxx from Dashboard → Subscriptions → Plans)
RAZORPAY_PLAN_PREMIUM=
RAZORPAY_PLAN_PREMIUM_PLUS=

# Webhook URL (production): https://your-domain.com/api/webhooks/razorpay
