# Copy to .env.local and fill in values from Supabase Dashboard → Project Settings → API
# Local development: SUPABASE_SERVICE_ROLE_KEY is OPTIONAL (UI + email auth work without it).
# Add SERVICE_ROLE_KEY only when testing subscriptions, billing APIs, or Razorpay webhooks.

# --- Required for app + auth ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key

# Server (same project — used by /api routes during dev/SSR)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_public_key

# --- Optional in local dev / required in production for billing ---
# Supabase Dashboard → API → service_role (secret — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: production site URL for SSR redirects
# VITE_SITE_URL=http://localhost:5173

# --- Razorpay (optional until testing payments) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
VITE_RAZORPAY_KEY_ID=
RAZORPAY_PLAN_PREMIUM=
RAZORPAY_PLAN_PREMIUM_PLUS=

# --- AI (optional until testing chat/analyze) ---
LOVABLE_API_KEY=
